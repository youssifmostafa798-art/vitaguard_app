# ── VitaGuard Backend Configuration ──────────────────────

# REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_BEFORE_RUNNING

# Database (default: SQLite for development)
DATABASE_URL=sqlite+aiosqlite:///./vitaguard.db
POSTGRES_USER=vitaguard
POSTGRES_PASSWORD=change-me
POSTGRES_DB=vitaguard

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# TFLite model path (relative to backend/)
TFLITE_MODEL_PATH=../model_optimized.tflite

# CORS (comma-separated origins)
#edit youssif 
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://10.0.2.2:8000

# File uploads
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=./uploads

# Environment
ENVIRONMENT=development

# API runtime
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
UVICORN_WORKERS=1
UVICORN_RELOAD=false
AUTO_APPLY_MIGRATIONS=false
LOG_LEVEL=info
