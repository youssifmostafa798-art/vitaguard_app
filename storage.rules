rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn() && userDoc().data.role == 'admin';
    }

    function isDoctor(doctorId) {
      return signedIn() && request.auth.uid == doctorId;
    }

    function isFacility(facilityId) {
      return signedIn() && request.auth.uid == facilityId;
    }

    function isPatient(patientId) {
      return signedIn() && request.auth.uid == patientId;
    }

    function isAssignedDoctor(patientId) {
      return signedIn()
        && firestore.get(/databases/(default)/documents/patients/$(patientId))
            .data.assignedDoctorId == request.auth.uid;
    }

    function isLinkedCompanion(patientId) {
      return signedIn()
        && firestore.get(/databases/(default)/documents/companions/$(request.auth.uid))
            .data.linkedPatientId == patientId;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isPdf() {
      return request.resource.contentType == 'application/pdf';
    }

    function sizeUnder(bytes) {
      return request.resource.size < bytes;
    }

    match /doctor_verifications/{doctorId}/{file} {
      allow read: if isAdmin() || isDoctor(doctorId);
      allow write: if (isDoctor(doctorId) && isImage() && sizeUnder(5 * 1024 * 1024)) || isAdmin();
    }

    match /facility_records/{facilityId}/{file} {
      allow read: if isAdmin() || isFacility(facilityId);
      allow write: if isFacility(facilityId) || isAdmin();
    }

    match /medical_records/{patientId}/{file} {
      allow read: if isPatient(patientId) || isAssignedDoctor(patientId) || isLinkedCompanion(patientId) || isAdmin();
      allow write: if (isPatient(patientId) && (isImage() || isPdf()) && sizeUnder(10 * 1024 * 1024)) || isAdmin();
    }

    match /xray_results/{patientId}/{file} {
      allow read: if isPatient(patientId) || isAssignedDoctor(patientId) || isLinkedCompanion(patientId) || isAdmin();
      allow write: if (isPatient(patientId) && isImage() && sizeUnder(10 * 1024 * 1024)) || isAdmin();
    }

    match /lab_reports/{facilityId}/{file} {
      allow read: if isFacility(facilityId) || isAdmin();
      allow write: if (isFacility(facilityId) && (isImage() || isPdf()) && sizeUnder(10 * 1024 * 1024)) || isAdmin();
    }

    match /lab_offers/{facilityId}/{file} {
      allow read: if true;
      allow write: if (isFacility(facilityId) && isImage() && sizeUnder(5 * 1024 * 1024)) || isAdmin();
    }
  }
}
